  description       String
  type              TicketType
  priority          Priority @default(MEDIUM)
  status            TicketStatus @default(OPEN)
  assignedTo        String?  // User ID
  assignedAt        DateTime?
  resolvedBy        String?
  resolvedAt        DateTime?
  resolution        String?
