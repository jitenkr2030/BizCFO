// BizCFO Platform - Complete Database Schema
// This schema supports all accounting and financial services automation

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ========================================
// ORGANIZATION & USER MANAGEMENT
// ========================================

model Organization {
  id                String   @id @default(cuid())
  name              String
  type              OrganizationType
  industry          String?
  gstin             String?  @unique
  pan               String?  @unique
  tan               String?
  cin               String?  // Corporate Identification Number
  registrationType  String?  // Regular, Composition, etc.
  gstCouncil        String?  // State, Central, Union Territory
  legalName         String?
  tradeName         String?
  address           Json?    // Complete address object
  contactInfo       Json?    // Email, phone, website
  billingAddress    Json?
  shippingAddress   Json?
  logoUrl           String?
  status            OrganizationStatus @default(ACTIVE)
  subscriptionPlan  SubscriptionPlan @default(STARTER)
  subscriptionEnds  DateTime?
  settings          Json?    // Organization-specific settings
  metadata          Json?    // Additional metadata
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  users             User[]
  clients           Client[]
  accounts          Account[]
  transactions      Transaction[]
  invoices          Invoice[]
  bills             Bill[]
  payments          Payment[]
  gstReturns        GSTReturn[]
  tdsRecords        TDSRecord[]
  taxDocuments      TaxDocument[]
  workflows         Workflow[]
  integrations      Integration[]
  reports           Report[]
  notifications     Notification[]
  auditLogs         AuditLog[]
  documents         Document[]
  bankAccounts      BankAccount[]
  expenses          Expense[]
  vendors           Vendor[]
  employees         Employee[]
  payroll           Payroll[]
  fixedAssets       FixedAsset[]
  inventory         Inventory[]
  projects          Project[]
  timeEntries       TimeEntry[]
  supportTickets    SupportTicket[]
  subscriptions     Subscription[]

  @@map("organizations")
}

model User {
  id                String   @id @default(cuid())
  email             String   @unique
  password          String
  name              String?
  phone             String?
  avatar            String?
  role              UserRole @default(USER)
  status            UserStatus @default(ACTIVE)
  lastLoginAt       DateTime?
  emailVerified     Boolean  @default(false)
  phoneVerified     Boolean  @default(false)
  twoFactorEnabled  Boolean  @default(false)
  twoFactorSecret   String?
  preferences       Json?    // User preferences
  metadata          Json?    // Additional metadata
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  organizationId    String?
  organization      Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  organizations     Organization[] @relation("UserOrganizations")
  clients           Client[]
  createdInvoices   Invoice[] @relation("CreatedBy")
  approvedInvoices  Invoice[] @relation("ApprovedBy")
  createdBills      Bill[] @relation("CreatedBy")
  approvedBills     Bill[] @relation("ApprovedBy")
  createdPayments   Payment[] @relation("CreatedBy")
  approvedPayments  Payment[] @relation("ApprovedBy")
  workflowExecutions WorkflowExecution[]
  supportTickets    SupportTicket[] @relation("AssignedTo")
  timeEntries       TimeEntry[]
  auditLogs         AuditLog[]
  notifications     Notification[]

  @@unique([email, organizationId])
  @@map("users")
}

model Client {
  id                String   @id @default(cuid())
  organizationId    String
  userId            String?
  name              String
  email             String?
  phone             String?
  company           String?
  gstin             String?
  pan               String?
  address           Json?
  billingAddress    Json?
  shippingAddress   Json?
  creditLimit       Decimal?
  outstandingAmount Decimal   @default(0)
  status            ClientStatus @default(ACTIVE)
  tags              String[]
  notes             String?
  metadata          Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user              User? @relation(fields: [userId], references: [id], onDelete: SetNull)
  invoices          Invoice[]
  projects          Project[]
  timeEntries       TimeEntry[]
  supportTickets    SupportTicket[]

  @@map("clients")
}

// ========================================
// ACCOUNTING & BOOKKEEPING
// ========================================

model Account {
  id                String   @id @default(cuid())
  organizationId    String
  name              String
  code              String?  // Account code
  type              AccountType
  subType           String?  // Sub-type for detailed classification
  parentId          String?
  description       String?
  openingBalance    Decimal  @default(0)
  currentBalance    Decimal  @default(0)
  currency          String   @default("INR")
  isActive          Boolean  @default(true)
  isSystem          Boolean  @default(false) // System accounts cannot be deleted
  level             Int      @default(1) // Account hierarchy level
  taxRate           Decimal? // For tax accounts
  bankDetails       Json?    // For bank accounts
  metadata          Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  parent            Account?  @relation("AccountHierarchy", fields: [parentId], references: [id])
  children          Account[] @relation("AccountHierarchy")
  transactions      Transaction[] @relation("FromAccount")
  transactionsTo    Transaction[] @relation("ToAccount")
  invoiceItems      InvoiceItem[]
  billItems         BillItem[]
  expenseItems      ExpenseItem[]
  journalEntries    JournalEntry[]

  @@unique([organizationId, code])
  @@map("accounts")
}

model Transaction {
  id                String   @id @default(cuid())
  organizationId    String
  fromAccountId     String
  toAccountId       String?
  amount            Decimal
  currency          String   @default("INR")
  exchangeRate      Decimal  @default(1)
  type              TransactionType
  category          String?
  subCategory       String?
  description       String
  referenceNumber   String?
  date              DateTime
  status            TransactionStatus @default(PENDING)
  reconciliationId  String?
  taxAmount         Decimal  @default(0)
  taxDetails        Json?    // Tax breakdown
  tags              String[]
  attachments       String[] // File URLs
  metadata          Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  fromAccount       Account @relation("FromAccount", fields: [fromAccountId], references: [id])
  toAccount         Account? @relation("ToAccount", fields: [toAccountId], references: [id])
  reconciliation    Reconciliation? @relation(fields: [reconciliationId], references: [id])
  invoice           Invoice?
  bill              Bill?
  payment           Payment?
  journalEntries    JournalEntry[]

  @@map("transactions")
}

model JournalEntry {
  id                String   @id @default(cuid())
  organizationId    String
  transactionId     String?
  accountId         String
  amount            Decimal
  type              JournalEntryType // DEBIT or CREDIT
  description       String?
  reference         String?
  date              DateTime
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  transaction       Transaction? @relation(fields: [transactionId], references: [id])
  account           Account @relation(fields: [accountId], references: [id])

  @@map("journal_entries")
}

model Reconciliation {
  id                String   @id @default(cuid())
  organizationId    String
  accountId         String
  statementDate     DateTime
  openingBalance    Decimal
  closingBalance    Decimal
  statementBalance  Decimal
  difference        Decimal
  status            ReconciliationStatus @default(PENDING)
  reconciledBy      String?
  reconciledAt      DateTime?
  notes             String?
  metadata          Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  account           Account @relation(fields: [accountId], references: [id])
  transactions      Transaction[]
  user              User? @relation(fields: [reconciledBy], references: [id])

  @@map("reconciliations")
}

// ========================================
// BILLING & INVOICING
// ========================================

model Invoice {
  id                String   @id @default(cuid())
  organizationId    String
  clientId          String
  invoiceNumber     String   @unique
  orderNumber       String?
  date              DateTime
  dueDate           DateTime
  subtotal          Decimal
  discountAmount    Decimal  @default(0)
  discountType      DiscountType?
  taxAmount         Decimal  @default(0)
  totalAmount       Decimal
  paidAmount        Decimal  @default(0)
  outstandingAmount Decimal
  currency          String   @default("INR")
  status            InvoiceStatus @default(DRAFT)
  paymentStatus     PaymentStatus @default(PENDING)
  paymentTerms      String?
  notes             String?
  terms             String?
  clientNotes       String?
  qrCode            String?  // UPI QR code
  paymentLink       String?
  createdById       String?
  approvedById      String?
  approvedAt        DateTime?
  sentAt            DateTime?
  viewedAt          DateTime?
  metadata          Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client            Client @relation(fields: [clientId], references: [id])
  items             InvoiceItem[]
  payments          Payment[]
  transactions      Transaction[]
  createdBy         User? @relation("CreatedBy", fields: [createdById], references: [id])
  approvedBy        User? @relation("ApprovedBy", fields: [approvedById], references: [id])
  gstDetails        GSTInvoiceDetails?
  reminders         InvoiceReminder[]

  @@unique([organizationId, invoiceNumber])
  @@map("invoices")
}

model InvoiceItem {
  id                String   @id @default(cuid())
  invoiceId         String
  accountId         String?  // Revenue account
  description       String
  hsnSacCode        String?
  quantity          Decimal
  unit              String?
  rate              Decimal
  amount            Decimal
  discountAmount    Decimal  @default(0)
  discountType      DiscountType?
  taxRate           Decimal  @default(0)
  taxAmount         Decimal  @default(0)
  totalAmount       Decimal
  metadata          Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  invoice           Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  account           Account? @relation(fields: [accountId], references: [id])

  @@map("invoice_items")
}

model Bill {
  id                String   @id @default(cuid())
  organizationId    String
  vendorId          String
  billNumber        String   @unique
  orderNumber       String?
  date              DateTime
  dueDate           DateTime
  subtotal          Decimal
  discountAmount    Decimal  @default(0)
  discountType      DiscountType?
  taxAmount         Decimal  @default(0)
  totalAmount       Decimal
  paidAmount        Decimal  @default(0)
  outstandingAmount Decimal
  currency          String   @default("INR")
  status            BillStatus @default(DRAFT)
  paymentStatus     PaymentStatus @default(PENDING)
  paymentTerms      String?
  notes             String?
  terms             String?
  createdById       String?
  approvedById      String?
  approvedAt        DateTime?
  metadata          Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  vendor            Vendor @relation(fields: [vendorId], references: [id])
  items             BillItem[]
  payments          Payment[]
  transactions      Transaction[]
  createdBy         User? @relation("CreatedBy", fields: [createdById], references: [id])
  approvedBy        User? @relation("ApprovedBy", fields: [approvedById], references: [id])
  gstDetails        GSTBillDetails?

  @@unique([organizationId, billNumber])
  @@map("bills")
}

model BillItem {
  id                String   @id @default(cuid())
  billId            String
  accountId         String?  // Expense account
  description       String
  hsnSacCode        String?
  quantity          Decimal
  unit              String?
  rate              Decimal
  amount            Decimal
  discountAmount    Decimal  @default(0)
  discountType      DiscountType?
  taxRate           Decimal  @default(0)
  taxAmount         Decimal  @default(0)
  totalAmount       Decimal
  metadata          Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  bill              Bill @relation(fields: [billId], references: [id], onDelete: Cascade)
  account           Account? @relation(fields: [accountId], references: [id])

  @@map("bill_items")
}

model Payment {
  id                String   @id @default(cuid())
  organizationId    String
  type              PaymentType
  referenceNumber   String?
  amount            Decimal
  currency          String   @default("INR")
  paymentMethod     PaymentMethod
  paymentDate       DateTime
  status            PaymentStatus @default(PENDING)
  description       String?
  notes             String?
  bankReference     String?
  transactionId     String?
  invoiceId         String?
  billId            String?
  createdById       String?
  approvedById      String?
  approvedAt        DateTime?
  metadata          Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invoice           Invoice? @relation(fields: [invoiceId], references: [id])
  bill              Bill? @relation(fields: [billId], references: [id])
  transaction       Transaction? @relation(fields: [transactionId], references: [id])
  createdBy         User? @relation("CreatedBy", fields: [createdById], references: [id])
  approvedBy        User? @relation("ApprovedBy", fields: [approvedById], references: [id])

  @@map("payments")
}

model InvoiceReminder {
  id                String   @id @default(cuid())
  invoiceId         String
  type              ReminderType
  scheduledFor      DateTime
  sentAt            DateTime?
  status            ReminderStatus @default(PENDING)
  template          String?
  customMessage     String?
  response          String?
  metadata          Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  invoice           Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("invoice_reminders")
}

// ========================================
// GST & TAX COMPLIANCE
// ========================================

model GSTReturn {
  id                String   @id @default(cuid())
  organizationId    String
  returnType        GSTReturnType // GSTR1, GSTR3B, GSTR9, etc.
  period            String   // YYYY-MM format
  fromDate          DateTime
  toDate            DateTime
  status            GSTReturnStatus @default(DRAFT)
  filingDate        DateTime?
  acknowledgementNumber String?
  totalTurnover     Decimal  @default(0)
  taxableTurnover   Decimal  @default(0)
  exemptTurnover    Decimal  @default(0)
  igstAmount        Decimal  @default(0)
  cgstAmount        Decimal  @default(0)
  sgstAmount        Decimal  @default(0)
  cessAmount        Decimal  @default(0)
  taxLiability      Decimal  @default(0)
  inputTaxCredit    Decimal  @default(0)
  netTax            Decimal  @default(0)
  lateFee           Decimal  @default(0)
  penalty           Decimal  @default(0)
  interest          Decimal  @default(0)
  totalAmount       Decimal  @default(0)
  data              Json?    // Complete return data
  errors            String[] // Validation errors
  submittedBy       String?
  approvedBy        String?
  metadata          Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, returnType, period])
  @@map("gst_returns")
}

model TDSRecord {
  id                String   @id @default(cuid())
  organizationId    String
  deducteeType      DeducteeType
  deducteeName      String
  deducteePAN       String?
  section           String   // TDS section
  amount            Decimal
  tdsRate           Decimal
  tdsAmount         Decimal
  paymentDate       DateTime
  depositDate       DateTime?
  challanNumber     String?
  bsrcode           String?
  bankName          String?
  branchName        String?
  status            TDSStatus @default(PENDING)
  quarter           String   // Q1, Q2, Q3, Q4
  financialYear     String   // YYYY-YY format
  certificateIssued Boolean  @default(false)
  certificateNumber String?
  metadata          Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("tds_records")
}

model TaxDocument {
  id                String   @id @default(cuid())
  organizationId    String
  type              TaxDocumentType
  name              String
  description       String?
  fileUrl           String
  fileSize          Int?
  fileType          String?
  documentNumber    String?
  issueDate         DateTime?
  expiryDate        DateTime?
  status            DocumentStatus @default(ACTIVE)
  tags              String[]
  metadata          Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("tax_documents")
}

model GSTInvoiceDetails {
  id                String   @id @default(cuid())
  invoiceId         String   @unique
  placeOfSupply     String?
  reverseCharge     Boolean  @default(false)
  ecommerceGstin    String?
  transporterId     String?
  vehicleNumber     String?
  lrNumber          String?
  lrDate            DateTime?
  shippingBillNumber String?
  shippingDate      DateTime?
  portCode          String?
  exportType        String?
  foreignCurrency   String?
  exchangeRate      Decimal  @default(1)
  gstDetails        Json?    // Detailed GST breakdown
  ewayBillNumber    String?
  ewayBillDate      DateTime?
  ewayBillValidUntil DateTime?
  metadata          Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  invoice           Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("gst_invoice_details")
}

model GSTBillDetails {
  id                String   @id @default(cuid())
  billId            String   @unique
  supplierGstin     String?
  supplierName      String?
  supplierAddress   Json?
  placeOfSupply     String?
  reverseCharge     Boolean  @default(false)
  itcAvailable      Boolean  @default(true)
  itcEligibility    String?  // ITC eligibility type
  gstDetails        Json?    // Detailed GST breakdown
  metadata          Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  bill              Bill @relation(fields: [billId], references: [id], onDelete: Cascade)

  @@map("gst_bill_details")
}

// ========================================
// VENDOR & EXPENSE MANAGEMENT
// ========================================

model Vendor {
  id                String   @id @default(cuid())
  organizationId    String
  name              String
  email             String?
  phone             String?
  company           String?
  gstin             String?
  pan               String?
  tan               String?
  msme              String?
  address           Json?
  billingAddress    Json?
  paymentTerms      String?
  creditLimit       Decimal?
  outstandingAmount Decimal   @default(0)
  status            VendorStatus @default(ACTIVE)
  tags              String[]
  notes             String?
  bankDetails       Json?    // Bank account details
  metadata          Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  bills             Bill[]
  expenses          Expense[]

  @@map("vendors")
}

model Expense {
  id                String   @id @default(cuid())
  organizationId    String
  vendorId          String?
  employeeId        String?
  projectId         String?
  reportId          String?  // Expense report ID
  category          String
  subCategory       String?
  description       String
  amount            Decimal
  currency          String   @default("INR")
  date              DateTime
  status            ExpenseStatus @default(PENDING)
  paymentStatus     PaymentStatus @default(PENDING)
  reimbursable      Boolean  @default(false)
  billable          Boolean  @default(false)
  clientBillable    Boolean  @default(false)
  receiptUrl        String?
  receiptNumber     String?
  taxAmount         Decimal  @default(0)
  taxDeductible     Boolean  @default(false)
  approvedBy        String?
  approvedAt        DateTime?
  paidBy            String?
  paidAt            DateTime?
  tags              String[]
  metadata          Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  vendor            Vendor? @relation(fields: [vendorId], references: [id])
  employee          Employee? @relation(fields: [employeeId], references: [id])
  project           Project? @relation(fields: [projectId], references: [id])
  items             ExpenseItem[]
  transactions      Transaction[]

  @@map("expenses")
}

model ExpenseItem {
  id                String   @id @default(cuid())
  expenseId         String
  accountId         String?  // Expense account
  description       String
  quantity          Decimal
  unit              String?
  rate              Decimal
  amount            Decimal
  taxRate           Decimal  @default(0)
  taxAmount         Decimal  @default(0)
  totalAmount       Decimal
  metadata          Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  expense           Expense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  account           Account? @relation(fields: [accountId], references: [id])

  @@map("expense_items")
}

// ========================================
// EMPLOYEE & PAYROLL
// ========================================

model Employee {
  id                String   @id @default(cuid())
  organizationId    String
  userId            String?  // Link to user if employee has login access
  employeeId        String   @unique
  firstName         String
  lastName          String?
  email             String?
  phone             String?
  dateOfBirth       DateTime?
  gender            Gender?
  bloodGroup        String?
  maritalStatus     String?
  fatherName        String?
  spouseName        String?
  address           Json?
  permanentAddress  Json?
  emergencyContact  Json?
  aadhaar           String?
  pan               String?
  passport          String?
  bankAccount       Json?    // Bank account details
  department        String?
  designation       String?
  employmentType    EmploymentType @default(FULL_TIME)
  workLocation      String?
  reportingTo       String?  // Employee ID
  dateOfJoining     DateTime
  dateOfLeaving     DateTime?
  status            EmployeeStatus @default(ACTIVE)
  salary            Decimal?
  ctc               Decimal?  // Cost to Company
  basicSalary       Decimal?
  hra               Decimal?
  allowances        Json?    // Various allowances
  deductions        Json?    // Various deductions
  pfNumber          String?
  esiNumber         String?
  professionalTax   Decimal?
  tdsApplicable     Boolean  @default(true)
  metadata          Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user              User? @relation(fields: [userId], references: [id])
  expenses          Expense[]
  payroll           Payroll[]
  timeEntries       TimeEntry[]
  leaves            Leave[]
  reportingToEmployee Employee? @relation("EmployeeReporting", fields: [reportingTo], references: [id])
  reportingEmployees Employee[] @relation("EmployeeReporting")

  @@unique([organizationId, employeeId])
  @@map("employees")
}

model Payroll {
  id                String   @id @default(cuid())
  organizationId    String
  employeeId        String
  payPeriod         String   // YYYY-MM format
  fromDate          DateTime
  toDate            DateTime
  paymentDate       DateTime
  status            PayrollStatus @default(DRAFT)
  workingDays       Int      @default(0)
  presentDays       Int      @default(0)
  leaveDays         Int      @default(0)
  holidays          Int      @default(0)
  overtimeHours     Decimal  @default(0)
  
  // Earnings
  basicSalary       Decimal  @default(0)
  hra               Decimal  @default(0)
  specialAllowance  Decimal  @default(0)
  conveyance        Decimal  @default(0)
  medicalAllowance  Decimal  @default(0)
  otherAllowances   Decimal  @default(0)
  overtimePay       Decimal  @default(0)
  bonus             Decimal  @default(0)
  incentives        Decimal  @default(0)
  arrears           Decimal  @default(0)
  grossSalary       Decimal  @default(0)
  
  // Deductions
  pfEmployee        Decimal  @default(0)
  pfEmployer        Decimal  @default(0)
  esiEmployee       Decimal  @default(0)
  esiEmployer       Decimal  @default(0)
  professionalTax   Decimal  @default(0)
  tds               Decimal  @default(0)
  advanceDeduction  Decimal  @default(0)
  otherDeductions   Decimal  @default(0)
  totalDeductions   Decimal  @default(0)
  
  // Net
  netSalary         Decimal  @default(0)
  takeHome          Decimal  @default(0)
  ctc               Decimal  @default(0)
  
  // Employer contributions
  employerPF        Decimal  @default(0)
  employerESI       Decimal  @default(0)
  gratuity          Decimal  @default(0)
  bonusProvision    Decimal  @default(0)
  leaveEncashment   Decimal  @default(0)
  totalCost         Decimal  @default(0)
  
  paymentMethod     PaymentMethod?
  bankReference     String?
  notes             String?
  approvedBy        String?
  approvedAt        DateTime?
  processedBy       String?
  processedAt       DateTime?
  metadata          Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relations
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  employee          Employee @relation(fields: [employeeId], references: [id])

  @@unique([organizationId, employeeId, payPeriod])
